{
  "name": "Magiteknical Energy",
  "type": "feat",
  "img": "icons/magic/lightning/bolt-strike-purple.webp",
  "system": {
    "description": {
      "value": "<p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">The energy source you've discovered could take many forms. Perhaps you've discovered a way to harness the power of steam, or maybe you stumbled upon a strange aberrant power source from the Far Realms. Discuss with your Dungeon Master what energy source is fueling your power charges. At 1st level, you can choose what kind of energy fuels your power charges (except for psychic damage, which is not permissible). This determines what type of damage your power charges will do and a number of other things within the technomancer class.</span></p><table class=\"article-table\" style=\"box-sizing:inherit;background:rgba(var(--theme-page-dynamic-color-1--rgb),.02);border:0 var(--theme-border-color);border-collapse:collapse;margin:1em 1em 1em 0px;color:rgb(58, 58, 58);font-family:rubik, helvetica, arial, sans-serif;font-size:14px;font-style:normal;font-variant-ligatures:normal;font-variant-caps:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-transform:none;widows:2;word-spacing:0px;-webkit-text-stroke-width:0px;white-space:normal;text-decoration-thickness:initial;text-decoration-style:initial;text-decoration-color:initial\"><tbody><tr style=\"box-sizing:inherit\"><th style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px;background:rgba(var(--theme-page-dynamic-color-1--rgb),.05);text-align:left\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Energy Example</span></p></th><th style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px;background:rgba(var(--theme-page-dynamic-color-1--rgb),.05);text-align:left\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Damage Type</span></p></th></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Combustion/ Steam</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Fire damage</span></p></td></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Alien Technology/ Gravity</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Force damage</span></p></td></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Ancient Battery</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Acid damage</span></p></td></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Electricity</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Lightning damage</span></p></td></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Dark Matter</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Necrotic damage</span></p></td></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Ultrasonic Sound</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Thunder damage</span></p></td></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Solar Power/ Divine Energy</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Radiant damage</span></p></td></tr><tr style=\"box-sizing:inherit\"><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">The Void</span></p></td><td style=\"box-sizing:inherit;border-bottom:1px solid var(--theme-border-color);padding:6px 12px\"><p><span style=\"font-family:rubik, helvetica, arial, sans-serif\">Cold damage</span></p></td></tr></tbody></table>",
